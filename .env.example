# Optional AI provider routing
# Supported provider: mock | zhipu | deepseek | kimi | minimax | seedance | compatible | custom
# LLM_PROVIDER supports comma-separated values, e.g. zhipu,deepseek
LLM_PROVIDER=mock
# Optional explicit fallback chain (higher priority than LLM_PROVIDER when set)
# LLM_PROVIDER_CHAIN=zhipu,deepseek,kimi,minimax,seedance

# Runtime JSON storage (non-DB mode)
# DATA_DIR=.runtime-data
# DATA_SEED_DIR=data

# Database
# DATABASE_URL=postgres://user:password@host:5432/dbname
# DB_SSL=false

# Zhipu (legacy generic vars still supported)
# LLM_PROVIDER=zhipu
# LLM_API_KEY=你的智谱API Key
# LLM_MODEL=glm-4.7
# LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# LLM_CHAT_PATH=/chat/completions

# DeepSeek
# DEEPSEEK_API_KEY=你的DeepSeek API Key
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# DEEPSEEK_CHAT_PATH=/chat/completions

# Kimi(Moonshot)
# KIMI_API_KEY=你的Kimi API Key
# KIMI_MODEL=moonshot-v1-8k
# KIMI_BASE_URL=https://api.moonshot.cn/v1
# KIMI_CHAT_PATH=/chat/completions

# MiniMax
# MINIMAX_API_KEY=你的MiniMax API Key
# MINIMAX_MODEL=MiniMax-Text-01
# MINIMAX_BASE_URL=https://api.minimax.chat/v1
# MINIMAX_CHAT_PATH=/chat/completions

# Seedance
# SEEDANCE_API_KEY=你的Seedance API Key
# SEEDANCE_MODEL=seedance-1.0
# SEEDANCE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# SEEDANCE_CHAT_PATH=/chat/completions

# OpenAI-compatible provider
# LLM_PROVIDER=compatible
# LLM_API_KEY=你的兼容接口API Key
# LLM_MODEL=你的模型名
# LLM_BASE_URL=你的兼容接口Base URL
# LLM_CHAT_PATH=/chat/completions

# Custom prompt endpoint
# LLM_PROVIDER=custom
# LLM_ENDPOINT=https://your-llm-endpoint
# LLM_API_KEY=

# Optional: auto-create admin when DB is empty
# ADMIN_BOOTSTRAP_EMAIL=admin@demo.com
# ADMIN_BOOTSTRAP_PASSWORD=Admin123
# ADMIN_BOOTSTRAP_NAME=管理员
# ALLOW_LEGACY_PLAIN_PASSWORDS=false

# Auth security: login lockout policy
# AUTH_SECURITY_ENFORCE=true
# AUTH_MAX_FAILED_ATTEMPTS=5
# AUTH_FAIL_WINDOW_MINUTES=15
# AUTH_LOCK_MINUTES=15
# AUTH_TRUST_PROXY_HEADERS=false

# Auth recovery abuse protection
# AUTH_RECOVERY_EMAIL_WINDOW_MINUTES=30
# AUTH_RECOVERY_EMAIL_MAX_ATTEMPTS=4
# AUTH_RECOVERY_IP_WINDOW_MINUTES=30
# AUTH_RECOVERY_IP_MAX_ATTEMPTS=12

# API same-origin protection for state-changing requests with session cookies
# API_ENFORCE_SAME_ORIGIN=true

# Admin high-risk action step-up
# ADMIN_STEP_UP_SECRET=replace_with_a_random_secret
# ADMIN_STEP_UP_TTL_MINUTES=10

# Protected readiness probe
# READINESS_PROBE_TOKEN=replace_with_a_random_secret

# Optional external error tracking webhook
# ERROR_TRACKING_WEBHOOK_URL=https://your-error-relay.example.com/events
# ERROR_TRACKING_TOKEN=replace_with_a_secret_token
# ERROR_TRACKING_APP=hk-ai-edu

# Auth security: password policy
# AUTH_PASSWORD_MIN_LENGTH=8
# AUTH_PASSWORD_REQUIRE_UPPERCASE=true
# AUTH_PASSWORD_REQUIRE_LOWERCASE=true
# AUTH_PASSWORD_REQUIRE_DIGIT=true

# Library list payload mode
# true  -> lightweight list payload (without contentBase64/textContent)
# false -> full payload for compatibility
# LIBRARY_LIGHT_LIST=true

# Library file object storage (local filesystem implementation)
# LIBRARY_OBJECT_STORAGE_ENABLED=true
# LIBRARY_INLINE_FILE_CONTENT=false
# OBJECT_STORAGE_ROOT=.runtime-data/objects

# Assignment uploads / module resources / class files object storage
# FILE_OBJECT_STORAGE_ENABLED=true
# FILE_INLINE_CONTENT=false

# Optional: invite code for admin self-registration
# ADMIN_ALLOW_INITIAL_SELF_REGISTER=false
# ADMIN_INVITE_CODE=your_invite_code

# Optional: invite code(s) for teacher self-registration
# TEACHER_ALLOW_INITIAL_SELF_REGISTER=false
# TEACHER_INVITE_CODE=HK-TEACH-2026
# TEACHER_INVITE_CODES=HK-TEACH-2026,HK-TEACH-2026-B

# Optional: invite code(s) for school-admin self-registration
# SCHOOL_ADMIN_ALLOW_INITIAL_SELF_REGISTER=false
# SCHOOL_ADMIN_INVITE_CODE=HK-SCHOOL-2026
# SCHOOL_ADMIN_INVITE_CODES=HK-SCHOOL-2026,HK-SCHOOL-2026-B
