  "scripts": {
    "postinstall": "node -e \"console.log('Using vendored workspace dist artifacts; skipping package rebuilds.')\"",
    "dev": "next dev",
    "build": "node scripts/build-next-clean.mjs",
    "start": "node scripts/start-next-production.mjs",
    "lint": "eslint .",
    "check": "prettier . --check",
    "check:i18n-keys": "node scripts/check-i18n-keys.mjs",
    "format": "prettier . --write",
    "project:snapshot": "node scripts/project-snapshot.mjs",
    "check:project-snapshot": "node scripts/project-snapshot.mjs --check",
    "test:unit": "node scripts/run-unit-tests.mjs",
    "test:api": "API_TEST_SCOPE=full API_TEST_ALLOW_CUSTOM_ORIGIN_HEADER=true API_TEST_SERVER_MODE=start API_TEST_FALLBACK_TO_DEV=0 node scripts/test-api-routes.mjs",
    "test:smoke": "API_TEST_SCOPE=smoke API_TEST_ALLOW_CUSTOM_ORIGIN_HEADER=true API_TEST_SERVER_MODE=start API_TEST_FALLBACK_TO_DEV=0 node scripts/test-api-routes.mjs",
    "test:school-schedules": "API_TEST_SUITE=school-schedules API_TEST_ALLOW_CUSTOM_ORIGIN_HEADER=true API_TEST_SERVER_MODE=start API_TEST_FALLBACK_TO_DEV=0 node scripts/test-api-routes.mjs",
    "test:smoke:production-like": "API_TEST_SUITE=smoke API_TEST_SERVER_MODE=start API_TEST_FALLBACK_TO_DEV=0 API_TEST_ALLOW_CUSTOM_ORIGIN_HEADER=false REQUIRE_DATABASE=true ALLOW_JSON_FALLBACK=false node scripts/test-api-routes.mjs",
    "test:school-schedules:production-like": "API_TEST_SUITE=school-schedules API_TEST_SERVER_MODE=start API_TEST_FALLBACK_TO_DEV=0 API_TEST_ALLOW_CUSTOM_ORIGIN_HEADER=false REQUIRE_DATABASE=true ALLOW_JSON_FALLBACK=false node scripts/test-api-routes.mjs",
    "test:smoke:remote": "API_TEST_SCOPE=smoke API_TEST_ALLOW_CUSTOM_ORIGIN_HEADER=true API_TEST_SERVER_MODE=remote API_TEST_FALLBACK_TO_DEV=0 node scripts/test-api-routes.mjs",
    "test:smoke:remote:self": "API_TEST_SCOPE=smoke API_TEST_ALLOW_CUSTOM_ORIGIN_HEADER=true API_TEST_REMOTE_SELF_TEST=true API_TEST_FALLBACK_TO_DEV=0 node scripts/test-api-routes.mjs",
    "verify:standalone-prompts": "node scripts/verify-standalone-prompts.mjs",
    "verify:postdeploy-smoke": "node scripts/post-deploy-smoke.mjs",
    "pretest:browser": "npm run build",
    "pretest:browser:headed": "npm run build",
    "pretest:a11y": "npm run build",
    "test:browser": "playwright test",
    "test:browser:built": "playwright test",
    "test:browser:production-like": "PLAYWRIGHT_FORCE_PRODUCTION_LIKE=true playwright test tests/browser/smoke.spec.ts",
    "test:browser:production-like:local": "PRODUCTION_LIKE_TEST_SCRIPT=test:browser:production-like bash scripts/run-production-like-smoke-local.sh",
    "test:browser:headed": "playwright test --headed",
    "test:a11y": "playwright test tests/browser/a11y.spec.ts",
    "test:a11y:serious": "npm run test:a11y",
    "test:visual": "node scripts/visual-check-local.mjs",
    "test": "npm run test:unit && npm run test:api",
    "verify": "npm run verify:strict",
    "verify:strict": "npm run lint && npm run check:i18n-keys && npm run check:project-snapshot && npm run build && npm run test:unit && npm run test:api && npm run test:a11y && npm run test:browser:built",
    "import:open-curriculum": "node scripts/import-open-curriculum-pack.mjs",
    "import:gaokao-bench": "node scripts/import-gaokao-bench-objective.mjs",
    "seed:library-db": "node scripts/seed-library-db.mjs",
    "db:init": "node scripts/init-db.mjs",
    "db:migrate": "node scripts/init-db.mjs",
    "seed:base": "node scripts/seed-db.mjs",
    "seed:stage3": "node scripts/seed-stage3.mjs",
    "seed:bulk": "node scripts/seed-bulk.mjs",
    "seed:hangke-flows": "node scripts/seed-hangke-realistic-flows.mjs",
    "seed:hangke-realistic": "node scripts/seed-hangke-realistic.mjs",
    "seed:showcase": "node scripts/seed-showcase.mjs",
    "infra:postgres:up": "docker compose -f docker-compose.local.yml up -d postgres",
    "infra:postgres:down": "docker compose -f docker-compose.local.yml down",
    "infra:postgres:logs": "docker compose -f docker-compose.local.yml logs -f postgres",
    "deploy:remote:prebuilt": "bash scripts/deploy-prebuilt-remote.sh",
    "test:smoke:production-like:local": "bash scripts/run-production-like-smoke-local.sh",
    "test:school-schedules:production-like:local": "PRODUCTION_LIKE_TEST_SCRIPT=test:school-schedules:production-like bash scripts/run-production-like-smoke-local.sh",
    "launch:readiness": "node scripts/launch-readiness-report.mjs",
    "export:users": "node scripts/export-users.mjs",
    "security:migrate-passwords": "node scripts/migrate-password-hash.mjs",
    "storage:migrate": "node scripts/migrate-file-payloads-to-object-storage.mjs",
    "runtime:migrate:p0": "node scripts/migrate-p0-runtime-state-to-db.mjs"
  },
